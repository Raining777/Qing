# === Qing AI Study Assistant ===
# Fill at least ONE LLM API Key below

# Anthropic (Recommended: Vision + deep reasoning)
ANTHROPIC_API_KEY=
ANTHROPIC_DEFAULT_MODEL=claude-sonnet-4-6

# DeepSeek (Recommended: cost-effective)
DEEPSEEK_API_KEY=
DEEPSEEK_DEFAULT_MODEL=deepseek-chat

# OpenAI (Optional)
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-4o

# Ollama local (Optional, no key needed)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_DEFAULT_MODEL=llama3.2

# === Embedding (Optional) ===
# Leave empty = local bge-large-en-v1.5 ONNX (~600MB)
# Fill = Voyage API cloud embedding (0 local memory)
VOYAGE_API_KEY=

# === App Settings ===
DEFAULT_LLM_PROVIDER=anthropic
PORT=7860
# Leave empty for no password
ACCESS_PASSWORD=
